# 黄金数据日报系统
# 环境配置 — 填写你自己的 Key
# 复制此文件为 .env 并填入真实值

FRED_API_KEY=your_fred_api_key_here
FRED_START_DATE=2015-01-01

# 飞书群机器人 Webhook（在飞书群设置 → 群机器人 → 添加自定义机器人）
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_token_here

# （可选）飞书签名校验 secret，如未开启签名则留空
FEISHU_SECRET=

# （可选）飞书 Open API — 用于上传图片到消息中
# 在 https://open.feishu.cn/app 创建企业自建应用，权限：im:resource
FEISHU_APP_ID=
FEISHU_APP_SECRET=
